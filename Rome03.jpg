      <script>window.__KLOOK__={"serverRendered":true,"data":[{"pageData":{"page":{"page_id":"destination_city_page-versionid:27503:platform:Default:areaid:0:language:Default:mapid:0","page_object_id":"Default","meta":{"type":"destination_city_page","track":{"iht_spm":"City","iht_extra_info":""}},"user_action":{"have_pull_to_refresh":true,"navigation_style":"","have_header":true,"have_pined_navigation_section":true,"have_footer":true},"body":{"sections":[{"meta":{"type":"any","placeholder":"","track":{"iht_spm":"BreadCrumb_LIST","iht_extra_info":null},"name":"DestinationBreadcrumb"},"data":null,"body":{"content":{"handler":"marketing","data_type":"DestinationBreadcrumb","load_type":"sync","src":"","track":null,"data":{"breadcrumb":[{"deep_link":"https:\u002F\u002Fwww.klook.com\u002Fen-US\u002F","name":"Home","type":"Home"},{"deep_link":"https:\u002F\u002Fwww.klook.com\u002Fen-US\u002Fdestination\u002Fco1027-italy\u002F","name":"Italy","type":"Dest_1027","dest_type":"country"},{"deep_link":"","name":"Rome","type":"dest_92","dest_type":"city"}]}}}},{"meta":{"type":"any","placeholder":"","track":{"iht_spm":"BreadCrumb_LIST","iht_extra_info":null},"name":"DestinationBreadcrumbV2"},"data":null,"body":{"content":{"handler":"marketing","data_type":"DestinationBreadcrumbV2","load_type":"sync","src":"","track":null,"data":{"breadcrumb":[{"deep_link":"https:\u002F\u002Fwww.klook.com\u002Fen-US\u002F","name":"Home","track_info":null},{"deep_link":"https:\u002F\u002Fwww.klook.com\u002Fen-US\u002Fdestination\u002Fco1027-italy\u002F","name":"Italy","track_info":{"extra":{"destination_id":1027}}},{"deep_link":"","name":"Rome","track_info":{"extra":{"destination_id":92}}}]}}}},{"meta":{"type":"any","placeholder":"","track":{"iht_spm":"DestCityIntro","iht_extra_info":null},"name":"DestinationBasicInfo"},"data":null,"body":{"content":{"handler":"marketing","data_type":"DestinationBasicInfo","load_type":"sync","src":"","track":null,"data":{"title":"Rome","desc":"Rome, Italy’s capital city, is the Eternal City, a living museum where ancient ruins, artistic treasures, and modern life blend beautifully. Here, you’ll find countless tourist attractions and iconic landmarks within walking distance of one another, from the grand Colosseum and Roman Forum to the elegant Piazza di Spagna and Spanish Steps.\n\nStart your first trip in the city center, where the Trevi Fountain, Piazza Navona, and Campo de Fiori are perfect spots to people-watch or enjoy amazing Italian food at local trattorias. Don’t miss a guided tour of Vatican City and its world-famous Vatican Museums, Sistine Chapel, and St. Peter’s Basilica—top highlights of Rome, Italy.\n\nThen, explore the ruins of Ancient Rome at the Palatine Hill and Roman Forum, where you’ll learn the history of the Roman Empire all around you. Walk through cobblestone streets of Centro Storico, or relax in the Villa Borghese Gardens, one of the most peaceful spots in this Italian city.\n\nIf you’re admiring Roman monuments, stopping by Piazza Venezia to see the Unknown Soldier, or exploring off the beaten path in the Jewish Quarter, every corner of Rome has its own story. Book your Rome activities and tours on Klook now and make the most of your Roman holiday!\n","image":{"mobile_banner":"https:\u002F\u002Fres.klook.com\u002Fimage\u002Fupload\u002FMobile\u002FCity\u002Fafmqgg5h0jl9wnr1dfmf.jpg","web_banner":"https:\u002F\u002Fres.klook.com\u002Fimage\u002Fupload\u002Fcities\u002Fn6pfqvaabvory1mhoh3q.jpg","card_banner":"https:\u002F\u002Fres.klook.com\u002Fimage\u002Fupload\u002Fcities\u002Fyg30e49yzlajoxo8lry6.jpg","original_banner":"https:\u002F\u002Fres.klook.com\u002Fimage\u002Fupload\u002Fdestination\u002Fhftmwjvg2mzcwfse02ye.jpg","tablet_banner":"https:\u002F\u002Fres.klook.com\u002Fimage\u002Fupload\u002Fcities\u002Fn6pfqvaabvory1mhoh3q.jpg"}}}}},{"meta":{"type":"any","placeholder":"","track":{"iht_spm":"CategoryTab_LIST","iht_extra_info":null},"name":"DestinationPageType"},"data":null,"body":{"content":{"